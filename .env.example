# ───────────────────────────────────────────────────────────────────────
#  El-Imtiyaz School System — Environment configuration
#  Copy this file to `.env` and adjust values as needed.
# ───────────────────────────────────────────────────────────────────────

# Application
APP_NAME="El-Imtiyaz School System"
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=debug              # error | warn | info | debug | silly
LOG_DIR=logs

# Database
DB_FILENAME=el-imtiyaz.db
DB_DIR=userdata

# Currency (ISO 4217)
CURRENCY_CODE=DZD
CURRENCY_SYMBOL=د.ج
CURRENCY_LOCALE=ar-DZ

# School identity (used on receipts & reports)
SCHOOL_NAME="El-Imtiyaz Private School"
SCHOOL_ADDRESS="Algiers, Algeria"
SCHOOL_PHONE="+213 00 00 00 00"
SCHOOL_EMAIL="contact@el-imtiyaz.dz"
